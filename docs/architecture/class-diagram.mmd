    %% ========================================
    %% RELATIONSHIPS
    %% ========================================

    %% Contact Management
    Contact "1" --> "*" Note : has
    Contact "*" --> "1" Company : belongs to
    Contact "*" <--> "*" Tag : tagged with
    Contact "*" <--> "*" ContactGroup : member of
    Contact "1" --> "*" Interaction : has
    Contact "1" --> "*" Deal : has

    %% Communication
    Communication <|-- EmailMessage : inherits
    Communication <|-- SMSMessage : inherits
    Communication <|-- WhatsAppMessage : inherits
    Communication <|-- ChatMessage : inherits

    Communication "*" --> "1" Channel : sent via
    Communication "*" --> "1" Contact : from/to

    %% Campaign & Template
    Campaign "*" --> "1" Template : uses
    Campaign "*" --> "1" Channel : sends through
    Campaign "*" <--> "*" ContactGroup : targets

    %% Pipeline
    Pipeline "1" --> "*" PipelineStage : contains
    PipelineStage "1" --> "*" Deal : contains
    Deal "*" --> "1" Contact : associated with
    Deal "*" --> "1" User : owned by

    %% Interaction
    Interaction "*" --> "1" Contact : relates to
    Interaction "*" --> "1" Channel : via
    Interaction "*" --> "1" User : performed by

    %% Notes
    Note "*" --> "1" Contact : belongs to
    Note "*" --> "1" User : authored by

    %% User & Team
    User "*" <--> "*" Team : member of

    %% Automation
    Automation "*" --> "*" Channel : uses
    Automation "*" --> "*" Template : uses

    %% Audit
    AuditLog "*" --> "1" User : performed by

    %% Custom Fields
    CustomField "*" --> "1" Contact : extends

